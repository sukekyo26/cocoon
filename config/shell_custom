# Custom shell configuration for workspace-docker
# This file is loaded automatically when you start a shell in the container,
# regardless of which shell you selected via [container.shell].default
# (bash / zsh / fish).
#
# Tip: simple aliases and env vars are easier to declare in workspace.toml
# under [container.shell].aliases / [container.shell].env — those are written
# to the .generated companion file with the right per-shell syntax. Use this
# file only for things workspace.toml cannot express, e.g. dynamic PATH
# manipulation, conditionals, sourcing other scripts.
#
# IMPORTANT: Use the syntax matching your active shell. Examples for both
# POSIX-style shells (bash / zsh) and fish are shown below — uncomment only
# the section that applies to your [container.shell].default. If you switch
# shells later, update this file accordingly.
#
# ===== bash / zsh (POSIX syntax) =====

# npm global binaries
NPM_PREFIX=$(npm config get prefix 2>/dev/null)
if [ -n "$NPM_PREFIX" ] && [ -d "$NPM_PREFIX/bin" ]; then
  export PATH="$NPM_PREFIX/bin:$PATH"
fi

# pnpm global binaries
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

