# Auto-generated by setup-docker.sh from [container.shell] of workspace.toml.
# DO NOT EDIT — your changes will be overwritten on next run.
# For persistent custom shell config, edit config/shell_custom instead.

# Environment variables
export EDITOR=vim
export PAGER='less -R'

# Aliases
alias ga='git add'
alias gb='git branch'
alias gc='git commit'
alias gco='git checkout'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate'
alias gp='git push'
alias gs='git status'
alias ll='ls -lah'
