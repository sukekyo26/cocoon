# Auto-generated from workspace.toml — do not edit directly.
services:
  ci-test:
    container_name: "${CONTAINER_SERVICE_NAME}"
    build:
      context: .
      args:
        - "OS_IMAGE=${OS_IMAGE}"
        - "OS_VERSION=${OS_VERSION}"
        - "USERNAME=${USERNAME}"
        - "UID=${UID}"
        - "GID=${GID}"
        - "DOCKER_GID=${DOCKER_GID}"
    user: "${UID}:${GID}"
    environment:
      - "CONTAINER_SERVICE_NAME=${CONTAINER_SERVICE_NAME}"
      - CI_TEST=true
      - NODE_ENV=development
      - TZ=Asia/Tokyo
    volumes:
      - "..:/home/${USERNAME}/workspace"
      - "local:/home/${USERNAME}/.local"
      - "aws:/home/${USERNAME}/.aws"
      - "config:/home/${USERNAME}/.config"
      - "claude:/home/${USERNAME}/.claude"
      - "copilot:/home/${USERNAME}/.copilot"
      - "proto:/home/${USERNAME}/.proto"
      - "mise:/home/${USERNAME}/.mise"
      - "bun:/home/${USERNAME}/.bun"
      - "cargo:/home/${USERNAME}/.cargo"
      - "rustup:/home/${USERNAME}/.rustup"
      - "go:/home/${USERNAME}/go"
      - "fonts:/home/${USERNAME}/.fonts"
      - "ci-data:/home/testuser/.ci-data"
      - "~/.gnupg:/home/testuser/.gnupg:ro"
    ports:
      - "3000:3000"
      - "8080:8080"
    extra_hosts:
      - "corp.example:10.0.0.42"
      - "db.local:host-gateway"
    dns:
      - 1.1.1.1
    dns_search:
      - corp.example.com
    sysctls:
      net.ipv4.ip_unprivileged_port_start: 0
    cap_add:
      - SYS_PTRACE
    cap_drop:
      - AUDIT_WRITE
    security_opt:
      - seccomp=unconfined
      - "no-new-privileges:true"
    tty: true
    init: true
    stop_grace_period: 60s
    shm_size: 2gb
    pids_limit: 8192
    ulimits:
      nofile:
        soft: 32768
        hard: 524288
    cpus: 4.0
    mem_limit: 8gb
  postgres:
    image: "postgres:16-alpine"
    init: true
    ports:
      - "5432:5432"
    environment:
      - POSTGRES_DB=app
      - POSTGRES_PASSWORD=dev
    volumes:
      - "postgres_data:/var/lib/postgresql/data"
    healthcheck:
      interval: 5s
      retries: 5
      test:
        - CMD-SHELL
        - pg_isready -U postgres
      timeout: 5s
    restart: unless-stopped
  redis:
    image: "redis:7-alpine"
    init: true
    ports:
      - "6379:6379"
    depends_on:
      - postgres
volumes:
  local:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_local"
  aws:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_aws"
  config:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_config"
  claude:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_claude"
  copilot:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_copilot"
  proto:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_proto"
  mise:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_mise"
  bun:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_bun"
  cargo:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_cargo"
  rustup:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_rustup"
  go:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_go"
  fonts:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_fonts"
  ci-data:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_ci-data"
  postgres_data:
    name: "${COMPOSE_PROJECT_NAME}_postgres_data"
