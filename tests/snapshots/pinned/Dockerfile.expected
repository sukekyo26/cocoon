# syntax=docker/dockerfile:1.7
# Auto-generated from workspace.toml — do not edit directly.
ARG OS_IMAGE=ubuntu
ARG OS_VERSION=24.04
FROM ${OS_IMAGE}:${OS_VERSION}

ARG USERNAME
ARG UID
ARG GID

# Rewrite upstream apt archive URLs to the configured [apt.mirror].url
RUN sed -i \
    -e 's|http://archive.ubuntu.com/ubuntu/|http://archive.ubuntu.com/ubuntu/|g' \
    -e 's|http://security.ubuntu.com/ubuntu/|http://archive.ubuntu.com/ubuntu/|g' \
    -e 's|http://ports.ubuntu.com/ubuntu-ports/|http://archive.ubuntu.com/ubuntu/|g' \
    /etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources 2>/dev/null || true

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    curl \
    wget \
    ca-certificates \
    gnupg \
    openssh-client \
    git \
    make \
    sudo \
    vim \
    nano \
    zip \
    unzip \
    tar \
    gzip \
    bzip2 \
    xz-utils \
    tree \
    jq \
    bc \
    less \
    rsync \
    procps \
    iproute2 \
    dnsutils \
    iputils-ping \
    net-tools \
    shellcheck \
    uuid-runtime \
    file \
    patch \
    gettext-base \
    fzf \
    bat \
    ripgrep \
    python3 \
    python3-pip \
    python3-venv \
    locales \
    zsh \
    zsh-autosuggestions \
    build-essential \
    libssl-dev \
    zlib1g-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    libncursesw5-dev \
    tk-dev \
    libxml2-dev \
    libxmlsec1-dev \
    libffi-dev \
    liblzma-dev \
    fontconfig \
    jq \
    tree \
    && locale-gen en_US.UTF-8 ja_JP.UTF-8 \
    && rm -rf /tmp/* /var/tmp/*

# === user-defined dockerfile.pre_user_setup (from workspace.toml) ===
RUN touch /etc/marker-pre-user-setup
# === end dockerfile.pre_user_setup ===

# Dotfiles seeded into the new user's home via /etc/skel
COPY config/shell_custom.example /etc/skel/.shell_skel_example

RUN existing_user="$(getent passwd ${UID} | cut -d: -f1)" && \
    if [ -n "$existing_user" ] && [ "$existing_user" != "${USERNAME}" ]; then \
        userdel -r "$existing_user" 2>/dev/null || true; \
    fi && \
    existing_group="$(getent group ${GID} | cut -d: -f1)" && \
    if [ -n "$existing_group" ] && [ "$existing_group" != "${USERNAME}" ]; then \
        groupdel "$existing_group" 2>/dev/null || true; \
    fi && \
    groupadd -g ${GID} ${USERNAME} && \
    useradd -m -s /usr/bin/zsh -u ${UID} -g ${GID} ${USERNAME} && \
    usermod -aG sudo ${USERNAME} && \
    echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} && \
    chmod 0440 /etc/sudoers.d/${USERNAME}

USER ${USERNAME}
WORKDIR /home/${USERNAME}

# Set locale environment variables
ENV LANG=ja_JP.UTF-8
ENV LANGUAGE=ja_JP:en
ENV LC_ALL=ja_JP.UTF-8

# Ensure the active login shell's rc file exists before any later RUN
# (plugin install scripts, cert env exports, completion init) appends to it
# via >> "$RC_FILE". fish in particular keeps its config under
# ~/.config/fish/, a path useradd does not pre-create.
RUN mkdir -p "$(dirname "$HOME/.zshrc")" && touch "$HOME/.zshrc"

# Enable zsh completion + autosuggestions
RUN echo 'autoload -Uz compinit && compinit' >> "$HOME/.zshrc" && \
    echo 'source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh 2>/dev/null || true' >> "$HOME/.zshrc"

# Git identity from [git] section of workspace.toml
USER root
RUN git config --system user.name  'CI Test' \
 && git config --system user.email ci@example.com
USER ${USERNAME}

# Prepare volume mount directories with correct ownership
USER root
RUN mkdir -p /home/${USERNAME}/.aws /home/${USERNAME}/.bun /home/${USERNAME}/.cargo /home/${USERNAME}/.claude /home/${USERNAME}/.config /home/${USERNAME}/.copilot /home/${USERNAME}/.fonts /home/${USERNAME}/.mise /home/${USERNAME}/.proto /home/${USERNAME}/.rustup /home/${USERNAME}/go /home/testuser/.ci-data && \
    chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.aws /home/${USERNAME}/.bun /home/${USERNAME}/.cargo /home/${USERNAME}/.claude /home/${USERNAME}/.config /home/${USERNAME}/.copilot /home/${USERNAME}/.fonts /home/${USERNAME}/.mise /home/${USERNAME}/.proto /home/${USERNAME}/.rustup /home/${USERNAME}/go /home/testuser/.ci-data
# Install Docker CLI
ARG DOCKER_GID
RUN --mount=type=bind,source=plugins/docker-cli,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    DOCKER_GID="${DOCKER_GID}" \
    bash /tmp/plugin/install.sh
# Install GitHub CLI
RUN --mount=type=bind,source=plugins/github-cli,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
# Install Zig
RUN --mount=type=bind,source=plugins/zig,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="0.13.0" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
# Install Go
RUN --mount=type=bind,source=plugins/go,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="1.23.4" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
ENV GOPATH="/home/${USERNAME}/go"
ENV PATH="/usr/local/go/bin:$GOPATH/bin:$PATH"
# Install lazygit
RUN --mount=type=bind,source=plugins/lazygit,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="0.44.1" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
# Install Starship
RUN --mount=type=bind,source=plugins/starship,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="1.21.1" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
# Install Google Chrome
RUN --mount=type=bind,source=plugins/google-chrome,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
# Install Terraform
RUN --mount=type=bind,source=plugins/terraform,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="1.10.5" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
# Install OpenTofu
RUN --mount=type=bind,source=plugins/opentofu,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="1.9.0" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
USER ${USERNAME}
# Install AWS CLI v2
RUN --mount=type=bind,source=plugins/aws-cli,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
# Install AWS SAM CLI
RUN --mount=type=bind,source=plugins/aws-sam-cli,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
# Install Claude Code
RUN --mount=type=bind,source=plugins/claude-code,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
# Install GitHub Copilot CLI
RUN --mount=type=bind,source=plugins/copilot-cli,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="0.0.369" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
# Install proto
RUN --mount=type=bind,source=plugins/proto,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="0.46.1" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
ENV PROTO_HOME="/home/${USERNAME}/.proto"
ENV PATH="$PROTO_HOME/shims:$PROTO_HOME/bin:$PATH"
# Install mise
RUN --mount=type=bind,source=plugins/mise,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="2025.12.0" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
ENV MISE_DATA_DIR="/home/${USERNAME}/.mise"
ENV PATH="/home/${USERNAME}/.local/bin:$PATH"
# Install uv
RUN --mount=type=bind,source=plugins/uv,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="0.5.7" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
ENV PATH="/home/${USERNAME}/.local/bin:$PATH"
# Install bun
RUN --mount=type=bind,source=plugins/bun,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="1.3.3" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install.sh
ENV BUN_INSTALL="/home/${USERNAME}/.bun"
ENV PATH="$BUN_INSTALL/bin:$PATH"
# Install Rust
RUN --mount=type=bind,source=plugins/rust,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
ENV PATH="/home/${USERNAME}/.cargo/bin:$PATH"
# Install Nerd Fonts
RUN --mount=type=bind,source=plugins/nerd-fonts,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    bash /tmp/plugin/install.sh
# Configure Starship (user)
RUN --mount=type=bind,source=plugins/starship,target=/tmp/plugin \
    RC_FILE="$HOME/.zshrc" \
    RC_SYNTAX="posix" \
    LOGIN_SHELL="zsh" \
    PIN="1.21.1" \
    CHECKSUM_AMD64="" \
    CHECKSUM_ARM64="" \
    bash /tmp/plugin/install_user.sh

# === user-defined dockerfile.post_plugins (from workspace.toml) ===
RUN sudo touch /etc/marker-post-plugins
# === end dockerfile.post_plugins ===

# Backup image-installed files for volume-mount resilience
RUN if [ -d ~/.local ]; then cp -a ~/.local ~/.image-local; else mkdir -p ~/.image-local; fi

# create volume mount directories for permission
RUN mkdir -p ~/.local

# Setup persistent shell history
RUN echo 'export HISTFILE=~/.local/state/.zsh_history_docker' >> "$HOME/.zshrc" && \
    echo 'export HISTSIZE=10000' >> "$HOME/.zshrc" && \
    echo 'export SAVEHIST=20000' >> "$HOME/.zshrc" && \
    mkdir -p ~/.local/state && touch ~/.local/state/.zsh_history_docker

# Custom configuration file support (config/shell_custom and optional config/.zshrc_custom.generated)
RUN echo '' >> "$HOME/.zshrc" && \
    echo '# Load auto-generated shell config from [container.shell] of workspace.toml' >> "$HOME/.zshrc" && \
    echo '[ -f "$HOME/workspace/cocoon/config/.zshrc_custom.generated" ] && . "$HOME/workspace/cocoon/config/.zshrc_custom.generated"' >> "$HOME/.zshrc" && \
    echo '# Load user-editable custom configuration from config/shell_custom' >> "$HOME/.zshrc" && \
    echo '[ -f "$HOME/workspace/cocoon/config/shell_custom" ] && . "$HOME/workspace/cocoon/config/shell_custom"' >> "$HOME/.zshrc"

# Entrypoint: sync image files to volume-mounted ~/.local
USER root
COPY config/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh
USER ${USERNAME}

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["sleep", "infinity"]

WORKDIR /home/${USERNAME}/workspace
