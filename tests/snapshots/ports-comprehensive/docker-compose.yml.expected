# Auto-generated from workspace.toml — do not edit directly.
services:
  ports:
    container_name: "${CONTAINER_SERVICE_NAME}"
    build:
      context: .
      args:
        - "OS_IMAGE=${OS_IMAGE}"
        - "OS_VERSION=${OS_VERSION}"
        - "USERNAME=${USERNAME}"
        - "UID=${UID}"
        - "GID=${GID}"
        - "DOCKER_GID=${DOCKER_GID}"
    user: "${UID}:${GID}"
    environment:
      - "CONTAINER_SERVICE_NAME=${CONTAINER_SERVICE_NAME}"
    volumes:
      - "..:/home/${USERNAME}/workspace"
      - "local:/home/${USERNAME}/.local"
    ports:
      - "3000"
      - "8080:80"
      - "127.0.0.1:5432:5432/tcp"
      - "3000-3005:3000-3005"
      - target: 9000
        published: 9000
        host_ip: 127.0.0.1
        protocol: udp
      - target: 9090
        mode: host
    tty: true
    init: true
    stop_grace_period: 30s
    shm_size: 1gb
    pids_limit: 4096
    ulimits:
      nofile:
        soft: 65536
        hard: 1048576
volumes:
  local:
    name: "${COMPOSE_PROJECT_NAME}_${CONTAINER_SERVICE_NAME}_local"
